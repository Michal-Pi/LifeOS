rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/profile/{docId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/settings/{docId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/notes/{noteId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/calendar/{docId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Agent runs workflow steps (Phase 6E) - server writes, user reads
    match /users/{userId}/runs/{runId}/workflowSteps/{stepId} {
      allow read: if isAuthenticated(userId);
      allow write: if false;
    }
    // Agent runs + related activity (user-owned)
    match /users/{userId}/runs/{runId} {
      allow read, write: if isAuthenticated(userId);
      match /events/{eventId} {
        allow read, write: if isAuthenticated(userId);
      }
      match /messages/{messageId} {
        allow read, write: if isAuthenticated(userId);
      }
      match /toolCalls/{toolCallId} {
        allow read, write: if isAuthenticated(userId);
      }
      match /expertCouncilTurns/{turnId} {
        allow read, write: if isAuthenticated(userId);
      }
    }
    // Agents + tooling (Agents module)
    match /users/{userId}/agents/{agentId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/agentTemplates/{templateId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/workflowTemplates/{templateId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/tools/{toolId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Workflows + runs (Agents module)
    match /users/{userId}/workflows/{workflowId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/workflows/{workflowId}/deepResearchRequests/{requestId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/workflows/{workflowId}/runs/{runId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/privateIntegrations/{document=**} {
      // Only the server (Admin SDK / Cloud Functions) may read/write private integration tokens
      allow read, write: if false;
    }
    match /users/{userId}/calendarWritebackQueue/{jobId} {
      // Clients can read their writeback queue status (for UI indicators)
      // Only server (Cloud Functions) can write to prevent forged jobs
      allow read: if isAuthenticated(userId);
      allow write: if false;
    }
    // Phase 2.9: Composite events (owner-only)
    match /users/{userId}/compositeEvents/{compositeId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Phase 2.9: Composite run logs (server-only writes, user can read)
    match /users/{userId}/compositeRuns/{runId} {
      allow read: if isAuthenticated(userId);
      allow write: if false; // Server-only
    }
    // Phase 2.10: Free/busy cache (owner-only)
    match /users/{userId}/freeBusyCache/{cacheId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Daily inspirational quotes collection
    match /quotes/{userId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Calendar Accounts (OAuth connection status)
    match /users/{userId}/calendarAccounts/{accountId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Calendar Sync State (sync status tracking)
    match /users/{userId}/calendarSyncState/{key} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/councilAnalytics/{workflowId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/councilCache/{cacheKey} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/pmProfile/{docId} {
      allow read, write: if isAuthenticated(userId);
    }
    match /users/{userId}/pmContexts/{contextId} {
      allow read, write: if isAuthenticated(userId);
      match /{document=**} {
        allow read, write: if isAuthenticated(userId);
      }
    }
    match /users/{userId}/promptLibrary/{templateId} {
      allow read, write: if isAuthenticated(userId);
      match /versions/{versionId} {
        allow read, write: if isAuthenticated(userId);
      }
    }
    // Calendars list (Phase 2.6)
    // Allow both collection queries and individual document access
    match /users/{userId}/calendars/{document=**} {
      allow read, write: if isAuthenticated(userId);
    }
    // Calendar Events
    match /users/{userId}/calendarEvents/{eventId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Recurrence instance map (server-managed, user-readable)
    match /users/{userId}/recurrenceInstanceMap/{docId} {
      allow read: if isAuthenticated(userId);
      allow write: if false; // Server-only writes
    }
    // Projects (Todo module)
    match /users/{userId}/projects/{projectId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Chapters (Todo module)
    match /users/{userId}/chapters/{chapterId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Tasks (Todo module)
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Topics (Notes module)
    match /users/{userId}/topics/{topicId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Sections (Notes module)
    match /users/{userId}/sections/{sectionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Attachments (Notes module)
    match /users/{userId}/attachments/{attachmentId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Habits (Habits module)
    match /users/{userId}/habits/{habitId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Incantations (Habits mindset module)
    match /users/{userId}/incantations/{incantationId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Habit Check-ins (Habits module)
    match /users/{userId}/habitCheckins/{checkinId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Intervention Presets (Mind module)
    match /users/{userId}/interventionPresets/{interventionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Intervention Sessions (Mind module)
    match /users/{userId}/interventionSessions/{sessionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Workout Plans (Training module)
    match /users/{userId}/workoutPlans/{planId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Workout Sessions (Training module)
    match /users/{userId}/workoutSessions/{sessionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Exercise Library (Training module)
    match /users/{userId}/exerciseLibrary/{exerciseId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Workout Templates (Training module - user subcollection)
    match /users/{userId}/workoutTemplates/{templateId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Workout Templates (Training module - legacy root level)
    match /workoutTemplates/{templateId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // System Intervention Presets (read-only for all authenticated users)
    match /systemInterventions/{interventionId} {
      allow read: if request.auth != null;
      allow write: if false;  // Admin only
    }
    // Mind interventions (system presets stored at root level)
    match /interventions/{interventionId} {
      allow read: if request.auth != null && resource.data.userId == 'system';
      allow write: if false; // Admin only
    }
    // Check-ins (Mind module - root level with userId field)
    match /checkIns/{checkInId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Mailbox Messages (prioritized messages from Gmail/Slack)
    match /users/{userId}/mailboxMessages/{messageId} {
      allow read: if isAuthenticated(userId);
      allow write: if false; // Server-only writes
    }
    // Mailbox subcollections (messages, syncs, settings under mailbox doc)
    match /users/{userId}/mailbox/{document=**} {
      allow read, write: if isAuthenticated(userId);
    }
    // Mailbox Syncs (sync history records)
    match /users/{userId}/mailboxSyncs/{syncId} {
      allow read: if isAuthenticated(userId);
      allow write: if false; // Server-only writes
    }
    // Slack Connections
    match /users/{userId}/slackConnections/{connectionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Slack Accounts (workspace metadata + monitored channels)
    match /users/{userId}/slackAccounts/{document=**} {
      allow read, write: if isAuthenticated(userId);
    }
    // Integrations (Slack app settings, etc.)
    match /users/{userId}/integrations/{document=**} {
      allow read, write: if isAuthenticated(userId);
    }
    // Channel Connections (unified across Gmail, Slack, LinkedIn, WhatsApp, Telegram)
    match /users/{userId}/channelConnections/{connectionId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Mailbox Drafts (TipTap composer state persistence)
    match /users/{userId}/mailboxDrafts/{draftId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Sender Personas (AI-researched contact profiles)
    match /users/{userId}/senderPersonas/{personaId} {
      allow read, write: if isAuthenticated(userId);
    }
    // Research Projects (autonomous deep research)
    match /users/{userId}/researchProjects/{projectId} {
      allow read, write: if isAuthenticated(userId);
      match /claims/{claimId} {
        allow read, write: if isAuthenticated(userId);
      }
    }
    // Contacts (Inner Circle CRM)
    match /users/{userId}/contacts/{contactId} {
      allow read, write: if isAuthenticated(userId);
      match /interactions/{interactionId} {
        allow read, write: if isAuthenticated(userId);
      }
    }
    // Contact Email Index (fast email-to-contact lookups for Tier 0 classifier)
    match /users/{userId}/contactEmailIndex/{email} {
      allow read: if isAuthenticated(userId);
      allow write: if false; // Server-only writes (auto-learn + import)
    }
    // Scheduling Links (owner CRUD)
    match /users/{userId}/schedulingLinks/{linkId} {
      allow read, write: if isAuthenticated(userId);
      // Bookings are server-only writes (Cloud Function creates on public booking)
      match /bookings/{bookingId} {
        allow read: if isAuthenticated(userId);
        allow write: if false;
      }
    }
    // Slug lookup index (server-only — public reads via Cloud Function)
    match /schedulingLinkSlugs/{slug} {
      allow read, write: if false;
    }
    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isAuthenticated(userId) {
    return request.auth != null && request.auth.uid == userId;
  }
}
