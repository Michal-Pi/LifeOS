{
  "name": "lifeos",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "pnpm --filter web-vite dev",
    "build:functions": "pnpm --filter functions build",
    "firebase:deploy": "pnpm run build:functions && turbo run build --filter web-vite && firebase deploy",
    "firebase:deploy:hosting": "turbo run build --filter web-vite && firebase deploy --only hosting",
    "firebase:deploy:functions": "pnpm run build:functions && firebase deploy --only functions",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.0",
    "turbo": "^1.13.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "firebase-functions": "^7.0.5"
  }
}
