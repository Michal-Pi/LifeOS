    "@lifeos/calendar": "file:./vendor/lifeos-calendar",
    "@lifeos/training": "file:./vendor/lifeos-training",
    "@types/express": "^4.17.25",
    "expr-eval": "^2.0.2",
    "express": "^4.22.1",
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^7.0.6",
    "google-auth-library": "^9.0.0",
    "googleapis": "^140.0.0",
